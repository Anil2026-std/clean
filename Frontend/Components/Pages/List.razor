@page "/list"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.ComponentModel.DataAnnotations
@using System.Linq.Expressions
@using Frontend.Model
@using Frontend.Service
@inject ApiHandler ApiHandler
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@using System.Net.Http.Headers

<PageTitle>User Directory</PageTitle>

<div class="page-container">
    <div class="page-header">
        <h2>User Directory</h2>
        <p>Manage system access credentials and review current registered users.</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert-container alert-danger">
            <span>@errorMessage</span>
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert-container alert-success">
            <span>@successMessage</span>
        </div>
    }

    <div class="content-grid">
        <!-- Add User Column -->
        <div class="glass-card">
            <h3 class="card-title">Create Credentials</h3>

            <EditForm Model="user" OnValidSubmit="HandleSubmit" FormName="createUserForm">
                <DataAnnotationsValidator />

                <!-- Profile Image -->
                <div class="form-group-custom">
                    <label>Profile Image (Optional)</label>
                    <div class="avatar-upload-container">
                        <div class="avatar-preview-wrapper">
                            @if (!string.IsNullOrEmpty(imagePreviewUrl))
                            {
                                <img src="@imagePreviewUrl" class="avatar-preview" alt="Preview" />
                                <button type="button" class="btn-remove-avatar" @onclick="ClearSelectedFile">×</button>
                            }
                            else
                            {
                                <div class="avatar-placeholder">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16" style="color: #94a3b8;">
                                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                                    </svg>
                                </div>
                            }
                        </div>
                        <div class="upload-btn-wrapper">
                            <button type="button" class="btn-select-avatar">Choose Image</button>
                            <InputFile OnChange="HandleFileSelected" accept="image/png, image/jpeg, image/gif, image/webp" />
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(uploadError))
                    {
                        <span class="error-text">@uploadError</span>
                    }
                </div>

                <div class="form-group-custom">
                    <label for="username">Username</label>
                    <div class="input-wrapper">
                        <input type="text"
                               @bind-value="user.Username"
                               @bind-value:event="oninput"
                               class="form-control-custom"
                               placeholder="Enter username"
                               id="username" />
                    </div>
                    <ValidationMessage For="@(() => user.Username)" class="error-text" />
                </div>

                <div class="form-group-custom">
                    <label for="password">Password</label>
                    <div class="input-wrapper">
                        <input type="password"
                               @bind-value="user.Password"
                               @bind-value:event="oninput"
                               class="form-control-custom"
                               placeholder="Enter secure password"
                               id="password" />
                    </div>
                    <ValidationMessage For="@(() => user.Password)" class="error-text" />
                </div>

                <ul class="rules-list">
                    <li class="rule-item @GetRuleClass(HasMinLength)">• At least 8 characters</li>
                    <li class="rule-item @GetRuleClass(HasUpper)">• One uppercase letter</li>
                    <li class="rule-item @GetRuleClass(HasNumber)">• One number</li>
                    <li class="rule-item @GetRuleClass(HasSpecial)">• One special character</li>
                </ul>

                <button type="submit" class="btn-submit" disabled="@(!isFormValid || isLoading)">
                    @if (isLoading)
                    {
                        <span>Saving User...</span>
                    }
                    else
                    {
                        <span>Add User</span>
                    }
                </button>
            </EditForm>
        </div>

        <!-- Users List Column -->
        <div class="glass-card">
            <h3 class="card-title">Registered Users</h3>

            @if (users == null)
            {
                <div class="state-container">
                    <p>Fetching user directories from server...</p>
                </div>
            }
            else if (users.Count == 0)
            {
                <div class="state-container">
                    <h5>No Registered Users</h5>
                    <p>Use the credentials panel to create a new user profile.</p>
                </div>
            }
            else
            {
                <div class="users-table-container">
                    <table class="users-table">
                        <thead>
                            <tr>
                                <th style="width: 60px;">Avatar</th>
                                <th>Username</th>
                                <th>Account Reference ID</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in users)
                            {
                                <tr class="user-row">
                                    <td>
                                        <div class="user-avatar">
                                            @if (!string.IsNullOrEmpty(u.ImageUrl))
                                            {
                                                <img src="@($"{imageServerUrl}{u.ImageUrl}")" alt="Avatar" class="user-avatar-img" />
                                            }
                                            else
                                            {
                                                @u.Username.Substring(0, Math.Min(2, u.Username.Length)).ToUpper()
                                            }
                                        </div>
                                    </td>
                                    <td class="username-cell">
                                        @u.Username
                                    </td>
                                    <td>
                                        <span class="user-badge">@u.Id.ToString().Substring(0, 8)...</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private CreateUserDto user = new();
    private List<UserDto> users = new();
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;

    private IBrowserFile? selectedFile;
    private string? imagePreviewUrl;
    private string? uploadError;
    private string imageServerUrl => Configuration["ImageServerUrl"] ?? "https://localhost:7180";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            var response = await ApiHandler.GetAsync<ApiResponse<IEnumerable<UserDto>>>(ApiEndpoints.UserList);
            if (response != null && response.IsSuccess && response.Data != null)
            {
                users = response.Data.ToList();
            }
            else
            {
                errorMessage = "Failed to load user list from backend API.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error retrieving user directory: {ex.Message}";
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadError = null;
        var file = e.File;
        if (file != null)
        {
            var maxFileSize = 10 * 1024 * 1024; // 10MB
            if (file.Size > maxFileSize)
            {
                uploadError = "File exceeds the 10MB size limit.";
                return;
            }

            var allowedExtensions = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp" };
            var extension = Path.GetExtension(file.Name).ToLowerInvariant();
            if (!allowedExtensions.Contains(extension))
            {
                uploadError = "Allowed file types: JPG, JPEG, PNG, GIF, WEBP.";
                return;
            }

            selectedFile = file;

            try
            {
                var resizedFile = await file.RequestImageFileAsync(file.ContentType, 200, 200);
                var buffer = new byte[resizedFile.Size];
                using var stream = resizedFile.OpenReadStream(maxFileSize);
                await stream.ReadExactlyAsync(buffer);
                imagePreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
            }
            catch (Exception ex)
            {
                uploadError = $"Error generating preview: {ex.Message}";
            }
        }
    }

    private void ClearSelectedFile()
    {
        selectedFile = null;
        imagePreviewUrl = null;
        uploadError = null;
    }

    private async Task HandleSubmit()
    {
        if (isLoading) return;

        isLoading = true;
        errorMessage = null;
        successMessage = null;

        string? uploadedImageUrl = null;

        if (selectedFile != null)
        {
            try
            {
                var tokenResponse = await ApiHandler.GetAsync<MediaResponse>("api/Media/get-token");
                if (tokenResponse == null || string.IsNullOrEmpty(tokenResponse.AccessToken))
                {
                    errorMessage = "Failed to obtain upload token from Media Server.";
                    isLoading = false;
                    return;
                }

                using var content = new MultipartFormDataContent();
                var fileContent = new StreamContent(selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(selectedFile.ContentType);
                content.Add(fileContent, "file", selectedFile.Name);

                using var uploadClient = new HttpClient();
                uploadClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", tokenResponse.AccessToken);

                var uploadUrl = $"{imageServerUrl}/api/Media/upload?folderName=avatars";
                var response = await uploadClient.PostAsync(uploadUrl, content);

                if (response.IsSuccessStatusCode)
                {
                    var uploadResult = await response.Content.ReadFromJsonAsync<UploadResultDto>();
                    uploadedImageUrl = uploadResult?.MediaUrl;
                }
                else
                {
                    var responseError = await response.Content.ReadAsStringAsync();
                    errorMessage = $"Media Server Upload Failed: {responseError}";
                    isLoading = false;
                    return;
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error uploading avatar: {ex.Message}";
                isLoading = false;
                return;
            }
        }

        user.ImageUrl = uploadedImageUrl;

        var responseUser = await ApiHandler.PostAsync<CreateUserDto, ApiResponse<UserDto>>(
            ApiEndpoints.CreateUser,
            user,
            isAuth: true
        );

        if (responseUser != null && responseUser.IsSuccess)
        {
            successMessage = $"User '{responseUser.Data?.Username}' created successfully!";
            user = new CreateUserDto();
            ClearSelectedFile();
            await LoadUsers();
        }
        else
        {
            errorMessage = responseUser?.Message ?? "Failed to register user.";
        }
        isLoading = false;
    }

    private bool HasMinLength => !string.IsNullOrEmpty(user.Password) && user.Password.Length >= 8;
    private bool HasUpper => !string.IsNullOrEmpty(user.Password) && user.Password.Any(char.IsUpper);
    private bool HasNumber => !string.IsNullOrEmpty(user.Password) && user.Password.Any(char.IsDigit);
    private bool HasSpecial => !string.IsNullOrEmpty(user.Password) && user.Password.Any(ch => !char.IsLetterOrDigit(ch));

    private bool IsPasswordValid => HasMinLength && HasUpper && HasNumber && HasSpecial;
    private bool isFormValid => !string.IsNullOrEmpty(user.Username) && user.Username.Length >= 3 && IsPasswordValid;

    private string GetRuleClass(bool condition)
    {
        return condition ? "text-success" : "text-danger";
    }
}